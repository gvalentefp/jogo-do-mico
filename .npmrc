# Expo/React Native + Metro expect a flat node_modules. pnpm's default isolated
# layout hides transitive deps (expo-modules-core, @babel/runtime, ...) from
# Metro, so we hoist. This is the documented pnpm + Expo setup.
node-linker=hoisted

# Nao rodar a verificacao de deps antes de cada script (ela falha por causa do
# build script ignorado do esbuild). Evita exit 1 em `pnpm --filter ... dev`.
verify-deps-before-run=false
